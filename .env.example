# Django
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
# Production: https://your.domain
CSRF_TRUSTED_ORIGINS=

# PostgreSQL (локально через setup-postgresql.bat)
POSTGRES_DB=newsystem
POSTGRES_USER=newsystem
POSTGRES_PASSWORD=newsystem
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Почта (SMTP для уведомлений BPM/СЭД; в dev — console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Для реальной отправки (пример):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@delayu.local

# Версия платформы для паспорта продукта и реестра
DELAYU_PLATFORM_VERSION=2.2.0

# #6 — глобальный демо-режим (read-only мутации)
DELAYU_DEMO_MODE=false
# Сгенерировать: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('UZHV_VAPID_PUBLIC_KEY='+v.public_key.decode()); print('UZHV_VAPID_PRIVATE_KEY='+v.private_key.decode())"
UZHV_VAPID_PUBLIC_KEY=
UZHV_VAPID_PRIVATE_KEY=

# Яндекс.Карты — https://developer.tech.yandex.ru/ (JavaScript API и HTTP Геокодер)
YANDEX_MAPS_API_KEY=

# DaData — подсказки при вводе (адрес, ФИО, телефон, e-mail, паспорт, организации)
# https://dadata.ru/profile/#info
DADATA_API_KEY=
DADATA_SECRET_KEY=

# Telegram Bot — https://core.telegram.org/bots#botfather (альтернатива URL в M41)
TELEGRAM_BOT_TOKEN=
# Секрет для POST /api/v1/telegram/<subsystem>/ (заголовок X-Telegram-Bot-Api-Secret-Token)
TELEGRAM_WEBHOOK_SECRET=

# Публичная форма /public/uzhv/appeal/ — задайте токен в prod
UZHV_PUBLIC_APPEAL_TOKEN=

# Webhook исходящих событий УЖВ (после seed — коннектор webhook_uzhv активен)
DELAYU_WEBHOOK_URL=
DELAYU_WEBHOOK_SECRET=
DELAYU_N8N_WEBHOOK_URL=

# IMAP входящей почты → M24 (Эксплуатация → Почта; seed подхватывает из env)
UZHV_IMAP_HOST=
UZHV_IMAP_PORT=993
UZHV_IMAP_USER=
UZHV_IMAP_PASSWORD=
UZHV_IMAP_FOLDER=INBOX
UZHV_IMAP_SSL=true

# Без TELEGRAM_BOT_TOKEN — писать в журнал доставки (dev)
DELAYU_TELEGRAM_DEMO_LOG=true

# Импорт жилфонда (ГИС ЖКХ CSV): data/gis_zhkh_fund.example.csv
# python manage.py uzhv_py01_import data/gis_zhkh_fund.example.csv --subsystem uzhv --kind fund

# Всё сразу: python manage.py setup_free_integrations
# Cron: python manage.py integrations_cron --all-uzhv

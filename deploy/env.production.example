# Production — скопируйте в /opt/delayu/.env и заполните.
# После install-server.sh пароль БД допишется из /root/delayu-db-credentials.txt

DEBUG=false
DJANGO_ENVIRONMENT=production
SECRET_KEY=CHANGE-ME-run-deploy-app-or-python-secrets

# Домен (без https://)
DOMAIN=uzhv.example.ru
ALLOWED_HOSTS=uzhv.example.ru,www.uzhv.example.ru
CSRF_TRUSTED_ORIGINS=https://uzhv.example.ru,https://www.uzhv.example.ru

# HSTS — включите после проверки HTTPS (секунды, 31536000 = 1 год)
SECURE_HSTS_SECONDS=
SECURE_HSTS_INCLUDE_SUBDOMAINS=false

POSTGRES_DB=delayu
POSTGRES_USER=delayu
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

DELAYU_DEMO_MODE=false
DELAYU_PLATFORM_VERSION=2.2.0
DELAYU_TELEGRAM_DEMO_LOG=false

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@uzhv.example.ru

# Web Push УЖВ — сгенерировать ключи на сервере:
# python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); ..."
UZHV_VAPID_PUBLIC_KEY=
UZHV_VAPID_PRIVATE_KEY=

YANDEX_MAPS_API_KEY=
DADATA_API_KEY=
DADATA_SECRET_KEY=

UZHV_PUBLIC_APPEAL_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# SENTRY_DSN=
